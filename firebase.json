{
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "functions": {
      "port": 5001
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "apphosting": {
      "port": 4000,
      "rootDirectory": "./",
      "startCommand": "npm run dev"
    },
    "storage": {
      "port": 9199
    },
    "singleProjectMode": true
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "C:\\BuildTemp\\web-output",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|wasm)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "sports-rostering",
          "appId": "1:363898653310:android:cd50ad3a75acb8c95ce62f",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "sports-rostering",
          "configurations": {
            "android": "1:363898653310:android:cd50ad3a75acb8c95ce62f",
            "ios": "1:363898653310:ios:075d70dc074aa36b5ce62f",
            "web": "1:363898653310:web:6e150d09b188a6e75ce62f"
          }
        }
      }
    }
  }
}
