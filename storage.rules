rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Team logos — any signed-in user can read.
    // Writes are denied for direct client uploads; the uploadTeamLogo Cloud Function
    // (which verifies admin status via Firestore) writes via Admin SDK instead.
    match /team_logos/{teamId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Profile photos (Phase 3)
    match /profile_photos/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
