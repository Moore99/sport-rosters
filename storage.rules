rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Team logos — any team member can read; only team admins can write.
    // We can't call Firestore from Storage rules, so we use a path convention:
    // team_logos/{teamId}.jpg — write requires auth (admin check enforced in app + Cloud Function).
    match /team_logos/{teamId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024  // 2 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Profile photos (Phase 3)
    match /profile_photos/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
